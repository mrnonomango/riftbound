<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Riftbound Tracker</title>

<style>

html,
body {
  margin: 0;
  width: 100%;
  height: 100%;
  overflow: hidden;
  background: transparent;
  font-family: Arial, sans-serif;
}

.overlay {
  position: relative;
  width: 1920px;
  height: 1080px;
}

.side {
  position: absolute;
  top: 0;
  bottom: 0;
  width: 420px;
  display: flex;
}

.left {
  left: 0;
}

.right {
  right: 0;
  justify-content: flex-end;
}

.panel {

  width: 300px;
  height: 100%;

  background:
    linear-gradient(
      180deg,
      #020611 0%,
      #071326 45%,
      #0d1e3f 100%
    );

  border: 2px solid #d8b45a;
}

.track {

  width: 92px;
  height: 100%;

  position: relative;

  background:
    linear-gradient(
      180deg,
      #020611 0%,
      #071326 45%,
      #0d1e3f 100%
    );

  border-left: 2px solid #d8b45a;
  border-right: 2px solid #d8b45a;
}

.markers {

  position: absolute;

  top: 40px;
  bottom: 40px;

  left: 0;
  right: 0;
}

.marker {

  position: absolute;

  left: 50%;

  transform: translateX(-50%);

  width: 54px;
  height: 54px;

  border-radius: 50%;

  display: flex;
  align-items: center;
  justify-content: center;

  background: #0b1e42;

  border: 3px solid #d8b45a;

  color: white;

  font-size: 18px;
  font-weight: bold;
}

.marker.lit {
  background: #2b5fa8;
}

.marker.current {

  background: #6cb6ff;

  border: 4px solid white;

  transform:
    translateX(-50%)
    scale(1.15);

  box-shadow:
    0 0 15px #6cb6ff,
    0 0 35px #6cb6ff;
}

</style>
</head>

<body>

<div class="overlay">

  <div class="side left">

    <div class="panel"></div>

    <div class="track">
      <div class="markers" id="leftTrack"></div>
    </div>

  </div>

  <div class="side right">

    <div class="track">
      <div class="markers" id="rightTrack"></div>
    </div>

    <div class="panel"></div>

  </div>

</div>

<script type="module">

import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js";

import {
  getDatabase,
  ref,
  onValue
} from "https://www.gstatic.com/firebasejs/10.12.0/firebase-database.js";

const firebaseConfig = {
  apiKey: "AIzaSyCGlW1px3ZbK1qVFwVK-v4gP-d9KSGVj0U",
  authDomain: "lore-counter-4e654.firebaseapp.com",
  databaseURL: "https://lore-counter-4e654-default-rtdb.firebaseio.com",
  projectId: "lore-counter-4e654"
};

const app = initializeApp(firebaseConfig);
const db = getDatabase(app);

const leftTrack = document.getElementById("leftTrack");
const rightTrack = document.getElementById("rightTrack");

const MAX = 10;

function render(el, val) {

  el.innerHTML = "";

  for (let i = MAX; i >= 0; i--) {

    const marker = document.createElement("div");

    marker.className = "marker";

    if (i <= val) {
      marker.classList.add("lit");
    }

    if (i === val) {
      marker.classList.add("current");
    }

    marker.textContent = i;

    const pos = ((MAX - i) / MAX) * 100;

    marker.style.top =
      `calc(${pos}% - 27px)`;

    el.appendChild(marker);
  }
}

onValue(ref(db, "riftbound/p1"), (snapshot) => {
  render(leftTrack, Number(snapshot.val()) || 0);
});

onValue(ref(db, "riftbound/p2"), (snapshot) => {
  render(rightTrack, Number(snapshot.val()) || 0);
});

</script>

</body>
</html>
